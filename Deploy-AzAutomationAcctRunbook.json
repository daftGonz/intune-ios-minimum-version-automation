{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "automationAccountName": {
            "type": "string"
        },
        "runbookName": {
            "type": "string"
        },
        "runbookScriptUri": {
            "type": "string",
            "defaultValue": "https://raw.githubusercontent.com/daftGonz/intune-ios-minimum-version-automation/refs/heads/main/Update%E2%80%91iOSMinimumOSVersion.ps1"
        },
        "INTUNE_ENV_URL": {
            "type": "string",
            "defaultValue": "https://graph.microsoft.com",
            "metadata": {
                "description": "Commercial = https://graph.microsoft.com, GCC High = https://graph.microsoft.us, DoD = https://dod-graph.microsoft.us, China (21Vianet) = https://microsoftgraph.chinacloudapi.cn"
            }
        },
        "INTUNE_POLICY_ID": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "ID of iOS compliance policy in Intune."
            }
        },
        "MAIL_RECIPIENT": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Optional: Email address that will receive notifications from the runbook."
            }
        },
        "MAIL_SENDER_UPN": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Optional: Sender mailbox UPN used for Graph Mail.Send (must have permission)."
            }
        }
    },
    "resources": [
        {
            "type": "Microsoft.Automation/automationAccounts",
            "apiVersion": "2023-11-01",
            "name": "[parameters('automationAccountName')]",
            "location": "[resourceGroup().location]",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "sku": {
                    "name": "Basic"
                }
            }
        },
        {
            "type": "Microsoft.Automation/automationAccounts/runbooks",
            "apiVersion": "2023-11-01",
            "name": "[concat(parameters('automationAccountName'), '/', parameters('runbookName'))]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
            ],
            "properties": {
                "runbookType": "PowerShell",
                "logProgress": true,
                "logVerbose": true,
                "publishContentLink": {
                    "uri": "[parameters('runbookScriptUri')]"
                }
            }
        },
        {
            "type": "Microsoft.Automation/automationAccounts/variables",
            "apiVersion": "2023-11-01",
            "name": "[concat(parameters('automationAccountName'), '/INTUNE_ENV_URL')]",
            "dependsOn": [
                "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
            ],
            "properties": {
                "value": "[concat('\"', parameters('INTUNE_ENV_URL'), '\"')]",
                "isEncrypted": false
            }
        },
        {
            "type": "Microsoft.Automation/automationAccounts/variables",
            "apiVersion": "2023-11-01",
            "name": "[concat(parameters('automationAccountName'), '/INTUNE_POLICY_ID')]",
            "dependsOn": [
                "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
            ],
            "properties": {
                "value": "[concat('\"', parameters('INTUNE_POLICY_ID'), '\"')]",
                "isEncrypted": false
            }
        },
        {
            "type": "Microsoft.Automation/automationAccounts/variables",
            "apiVersion": "2023-11-01",
            "name": "[concat(parameters('automationAccountName'), '/MAIL_RECIPIENT')]",
            "dependsOn": [
                "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
            ],
            "properties": {
                "value": "[concat('\"', parameters('MAIL_RECIPIENT'), '\"')]",
                "isEncrypted": false
            }
        },
        {
            "type": "Microsoft.Automation/automationAccounts/variables",
            "apiVersion": "2023-11-01",
            "name": "[concat(parameters('automationAccountName'), '/MAIL_SENDER_UPN')]",
            "dependsOn": [
                "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
            ],
            "properties": {
                "value": "[concat('\"', parameters('MAIL_SENDER_UPN'), '\"')]",
                "isEncrypted": false
            }
        }
    ]
}
